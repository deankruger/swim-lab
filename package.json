{
    "name": "swim-lab",
    "version": "1.0.0",
    "description": "Web app to anaylse swimming results",
    "scripts": {
        "build": "npm run build:server && webpack --mode=production",
        "build:server": "tsc -p tsconfig.server.json",
        "build:dev": "webpack --mode=development",
        "dev": "webpack --mode=development --watch",
        "dev:server": "tsc -p tsconfig.server.json && node server.js",
        "serve": "webpack serve --mode=development",
        "start": "node server.js"
    },
    "keywords": [
        "swimming",
        "results",
        "analyzer",
        "lab"
    ],
    "author": "private",
    "license": "MIT",
    "devDependencies": {
        "@types/react": "^19.2.13",
        "@types/react-dom": "^19.2.3",
        "copy-webpack-plugin": "^13.0.1",
        "css-loader": "^7.1.3",
        "html-webpack-plugin": "^5.6.6",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "webpack": "^5.105.0",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.3"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.2.0",
        "cheerio": "^1.2.0",
        "exceljs": "^4.4.0",
        "express": "^4.21.2",
        "http-proxy-middleware": "^3.0.0",
        "nodemailer": "^6.9.7",
        "pdf-parse": "^2.4.5",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "xlsx": "^0.18.5"
    }
}
